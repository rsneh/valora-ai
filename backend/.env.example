# Database Configuration
DATABASE_URL=postgresql://your_user:your_password@db:5432/your_database

# Google Cloud Platform
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-service-account-key.json
GCS_BUCKET_NAME=your-gcs-bucket-name

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id

# Email Service (Brevo)
BREVO_API_KEY=your-brevo-api-key

# Google APIs
GOOGLE_API_KEY=your-google-api-key

# LangChain/LangSmith Configuration (Optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-api-key
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com

# Environment
ENVIRONMENT=development
DEBUG=true

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Redis Configuration (Optional - for future use)
# REDIS_URL=redis://localhost:6379/0

# Sentry Configuration (Optional - for error tracking)
# SENTRY_DSN=your-sentry-dsn